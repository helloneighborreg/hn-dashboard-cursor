{
	// Deploy with: npm run deploy:cloudflare  (uses --keep-vars so dashboard secrets are not wiped)
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hn-dashboard-cursor",
	"main": "worker.js",
	"triggers": {
		// Sync turnover tasks from Hospitable every 30 minutes (UTC).
		"crons": ["*/30 * * * *"]
	},
	"compatibility_date": "2025-04-01",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"routes": [
		{
			"pattern": "team.stayhn.com",
			"custom_domain": true
		}
	],
	// Non-secret config only — keep tokens/passwords in Cloudflare dashboard (Settings → Variables and Secrets).
	"vars": {
		"FILLOUT_CHECKLIST_FORMS": "{\"cjc\":\"https://helloneighbor.fillout.com/cascadesturncleanchecklist\",\"kwd502\":\"https://helloneighbor.fillout.com/kirkwoodturncleanchecklist\"}",
		"FILLOUT_URL_PARAM_MAP": "{\"property\":\"Property\",\"guest\":\"Guest\",\"reservation_id\":\"ReservationID\",\"checkout_date\":\"CheckOut\",\"task_id\":\"TaskID\"}"
	},
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "hn-dashboard-cursor"
		}
	],
	"observability": {
		"enabled": true
	}
}
