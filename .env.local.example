# Option A (easiest): edit env.local in the project root (no leading dot).
# Option B: copy this file to .env.local:
#   cp .env.local.example .env.local

# Required — password to sign in to the dashboard
DASHBOARD_PASSWORD=your_password_here

# Required — Hospitable API token (from https://app.hospitable.com)
HOSPITABLE_API_TOKEN=your_hospitable_token_here

# Optional — session encryption (use any random 32+ character string)
SESSION_SECRET=change_me_to_a_long_random_string_32chars
