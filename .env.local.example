# Copy to .env.local (or env.local) and fill in values:
#   cp .env.local.example .env.local

# Required — encrypts login sessions (32+ random characters)
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Required — dashboard logins (one line, valid JSON)
# Generate with: node scripts/print-dashboard-users.mjs --brandi-password brandi
DASHBOARD_USERS=[{"username":"josiah","name":"Josiah Burton","role":"admin","password":"your-admin-password"},{"username":"brandi","name":"Brandi Drieslein","role":"cleaner","password":"brandi","email":"brandi@helloneighbor.com"}]

# Legacy single-admin login (optional if DASHBOARD_USERS is set)
# DASHBOARD_PASSWORD=your_password_here

# Required — Hospitable API token
HOSPITABLE_API_TOKEN=your_hospitable_token_here

# Required — Supabase (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Optional — Plaid bank feed (https://dashboard.plaid.com)
# PLAID_CLIENT_ID=your_plaid_client_id
# PLAID_SECRET=your_plaid_secret
# PLAID_ENV=sandbox

# Required for task checklists (Fillout turnover forms)
# CJC properties share one form; KWD502 uses another — see supabase/README.md
# FILLOUT_CHECKLIST_FORMS={"cjc":"https://forms.fillout.com/t/your-cjc-form","kwd502":"https://forms.fillout.com/t/your-kwd-form"}
# Optional: single form for all properties instead of FILLOUT_CHECKLIST_FORMS
# FILLOUT_CHECKLIST_BASE_URL=https://forms.fillout.com/t/your-form-id
# FILLOUT_WEBHOOK_SECRET=choose-a-long-random-string
# FILLOUT_API_TOKEN=sk_prod_...   # For backfill: npm run db:backfill-fillout
# Optional override if form auto-detection fails:
# FILLOUT_FORM_IDS={"cjc":"your-cjc-form-id","kwd502":"your-kwd-form-id"}
#
# When a cleaner submits the checklist form, Fillout should POST to:
#   https://your-deployed-domain.com/api/webhooks/fillout
# Header: x-fillout-secret: <same value as FILLOUT_WEBHOOK_SECRET>
#
# In each Fillout form, map URL parameters task_id and reservation_id to hidden
# fields (prefilled from the checklist link). The dashboard sends these automatically
# on every "Open Checklist" link.
